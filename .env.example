# Copy to .env and fill in. Do NOT commit your real .env.

# SQLite database file.
DATABASE_URL="file:./dev.db"

# NextAuth / Auth.js secret — generate with: npx auth secret
# (or: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))")
AUTH_SECRET=""

# Stripe. Test keys: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Admin account created by `npx prisma db seed`.
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="changeme123"
