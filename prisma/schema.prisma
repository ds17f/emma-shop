// Emma Shop data model. SQLite + Prisma.
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Category {
  id       String    @id @default(cuid())
  name     String
  slug     String    @unique
  products Product[]

  createdAt DateTime @default(now())
}

model Product {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String  @default("")
  active      Boolean @default(true)
  featured    Boolean @default(false)

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  images   ProductImage[]
  variants Variant[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProductImage {
  id        String  @id @default(cuid())
  url       String
  alt       String  @default("")
  position  Int     @default(0)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Variant {
  id         String  @id @default(cuid())
  label      String // e.g. "Large / Blue"; "Default" for single-variant products
  sku        String? @unique
  priceCents Int // price in cents
  stock      Int     @default(0)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  orderItems OrderItem[]

  createdAt DateTime @default(now())
}

// Order.status is one of: PENDING | PAID | SHIPPED | FULFILLED | CANCELLED
// (stored as a string because SQLite has no native enum support)
model Order {
  id              String  @id @default(cuid())
  status          String  @default("PENDING")
  email           String
  customerName    String  @default("")
  shippingAddress String  @default("") // JSON string snapshot from Stripe
  totalCents      Int     @default(0)
  refundedCents   Int     @default(0) // cumulative amount refunded via Stripe
  stripeSessionId String? @unique
  stripePaymentIntentId String? // captured at fulfillment; used for refunds

  items OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrderItem {
  id           String @id @default(cuid())
  // snapshot of what was purchased (survives product edits/deletes)
  nameSnapshot String
  priceCents   Int
  quantity     Int

  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variantId String?
  variant   Variant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
}

model AdminUser {
  id           String @id @default(cuid())
  email        String @unique
  passwordHash String
  name         String @default("")

  createdAt DateTime @default(now())
}

// Singleton row (id = "store") holding shop-wide settings editable from the admin.
model StoreSettings {
  id           String @id @default("store")
  shopName     String @default("Comet Tail Crafts")
  tagline      String @default("Handmade goods from across the galaxy")
  contactEmail String @default("")

  // Appearance (admin "Appearance" page). logoUrl = uploaded logo (null → the
  // /logo.png default). themeJson = JSON map of color-token overrides (null →
  // the globals.css palette). See src/lib/theme.ts.
  logoUrl   String?
  themeJson String?

  // Shipping (cents). freeShippingThresholdCents = null disables the free tier.
  shippingFlatCents          Int  @default(700)
  freeShippingThresholdCents Int?

  updatedAt DateTime @updatedAt
}
